# OpenAI API Key (required for AI chat feature)
OPENAI_API_KEY=your_openai_api_key_here

# GitHub Personal Access Token (optional, increases rate limits)
GITHUB_TOKEN=your_github_token_here

# Upstash Redis (optional, for production rate limiting)
UPSTASH_REDIS_REST_URL=optional_for_production_rate_limiting
UPSTASH_REDIS_REST_TOKEN=optional_for_production_rate_limiting

# Resend API Key (optional, for contact form email delivery)
RESEND_API_KEY=optional_for_contact_form

# Contact email destination
CONTACT_EMAIL=karansinghsisodia@gmail.com
